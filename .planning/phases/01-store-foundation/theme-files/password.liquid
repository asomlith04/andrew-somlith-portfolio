{% layout none %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="{{ shop.name }} — Luxury animal print MacBook cases. Coming soon.">
  <title>{{ shop.name }} — Coming Soon</title>
  <style>
    /* ============================================================
       FAUNA LUXE — Coming Soon Page
       Cream & beige palette:
         #F5F0E8  warm cream (background)
         #EDE5D0  mid cream (card surfaces)
         #D4C5A9  warm beige (borders, accents)
         #B8A88A  dark beige (secondary UI)
         #6B5E4E  warm brown-grey (secondary text)
         #2C2C2C  near-black (primary text)
       NOTE: All CSS inline — external theme assets do not load
       on password pages ({% layout none %} bypasses theme.liquid)
    ============================================================ */

    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      font-size: 16px;
      -webkit-text-size-adjust: 100%;
    }

    body {
      background-color: #F5F0E8;
      color: #2C2C2C;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ---- Hero ---- */
    .hero {
      position: relative;
      width: 100%;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem 1.25rem 4rem;
      text-align: center;
      overflow: hidden;
    }

    .hero__bg {
      position: absolute;
      inset: 0;
      background-image: url('https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=1200&q=80');
      /* cream desk aesthetic — leopard print texture mood */
      background-size: cover;
      background-position: center 30%;
      z-index: 0;
    }

    .hero__overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        180deg,
        rgba(245, 240, 232, 0.70) 0%,
        rgba(245, 240, 232, 0.55) 40%,
        rgba(245, 240, 232, 0.82) 80%,
        rgba(245, 240, 232, 1.00) 100%
      );
      z-index: 1;
    }

    .hero__content {
      position: relative;
      z-index: 2;
      max-width: 600px;
      width: 100%;
    }

    /* ---- Brand wordmark ---- */
    .brand-wordmark {
      font-family: Georgia, 'Times New Roman', serif;
      font-size: clamp(2rem, 10vw, 4rem);
      font-weight: 400;
      letter-spacing: 0.22em;
      color: #2C2C2C;
      text-transform: uppercase;
      line-height: 1.1;
      margin-bottom: 0.6rem;
    }

    .brand-tagline {
      font-family: Georgia, 'Times New Roman', serif;
      font-size: clamp(0.8rem, 3.5vw, 1rem);
      font-weight: 400;
      font-style: italic;
      letter-spacing: 0.08em;
      color: #6B5E4E;
      margin-bottom: 2.5rem;
    }

    /* ---- Divider ---- */
    .divider {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin: 0 auto 2.5rem;
      max-width: 220px;
    }

    .divider__line {
      flex: 1;
      height: 1px;
      background-color: #D4C5A9;
    }

    .divider__dot {
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background-color: #B8A88A;
    }

    /* ---- Countdown ---- */
    .countdown {
      display: flex;
      gap: clamp(0.75rem, 4vw, 1.75rem);
      justify-content: center;
      margin-bottom: 2.75rem;
    }

    .countdown__unit {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.3rem;
    }

    .countdown__value {
      font-family: Georgia, 'Times New Roman', serif;
      font-size: clamp(2rem, 9vw, 3.5rem);
      font-weight: 400;
      color: #2C2C2C;
      line-height: 1;
      min-width: 2ch;
    }

    .countdown__label {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-size: 0.6rem;
      letter-spacing: 0.18em;
      color: #B8A88A;
      text-transform: uppercase;
    }

    /* ---- Email capture ---- */
    .capture {
      width: 100%;
      max-width: 440px;
      margin: 0 auto 2rem;
    }

    .capture__headline {
      font-family: Georgia, 'Times New Roman', serif;
      font-size: clamp(1rem, 4vw, 1.2rem);
      font-weight: 400;
      color: #2C2C2C;
      margin-bottom: 0.4rem;
      line-height: 1.4;
    }

    .capture__subtext {
      font-size: 0.8rem;
      color: #6B5E4E;
      letter-spacing: 0.04em;
      margin-bottom: 1.1rem;
    }

    .capture__form {
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
    }

    .capture__input {
      width: 100%;
      padding: 0.85rem 1rem;
      background: rgba(255, 255, 255, 0.75);
      border: 1px solid #D4C5A9;
      border-radius: 2px;
      font-size: 0.9rem;
      color: #2C2C2C;
      font-family: inherit;
      outline: none;
      transition: border-color 0.2s ease;
      -webkit-appearance: none;
    }

    .capture__input::placeholder {
      color: #B8A88A;
    }

    .capture__input:focus {
      border-color: #6B5E4E;
    }

    .capture__btn {
      width: 100%;
      padding: 0.9rem 1.5rem;
      background-color: #2C2C2C;
      color: #F5F0E8;
      border: none;
      border-radius: 2px;
      font-size: 0.75rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-family: inherit;
      cursor: pointer;
      transition: background-color 0.2s ease;
    }

    .capture__btn:hover,
    .capture__btn:focus {
      background-color: #6B5E4E;
    }

    .capture__success {
      text-align: center;
      padding: 1.25rem;
      background: rgba(212, 197, 169, 0.18);
      border: 1px solid #D4C5A9;
      border-radius: 2px;
    }

    .capture__success p {
      font-family: Georgia, 'Times New Roman', serif;
      font-size: 0.95rem;
      font-style: italic;
      color: #6B5E4E;
      line-height: 1.5;
    }

    .capture__errors {
      color: #8B4444;
      font-size: 0.8rem;
      margin-bottom: 0.5rem;
    }

    /* ---- Brand story ---- */
    .brand-story {
      width: 100%;
      max-width: 480px;
      margin: 0 auto 2.5rem;
      padding: 1.5rem 1.25rem;
      border-top: 1px solid #D4C5A9;
      border-bottom: 1px solid #D4C5A9;
    }

    .brand-story p {
      font-family: Georgia, 'Times New Roman', serif;
      font-size: clamp(0.82rem, 3vw, 0.95rem);
      line-height: 1.75;
      color: #6B5E4E;
      text-align: center;
    }

    /* ---- Password gate (subtle — bottom of page) ---- */
    .password-gate {
      margin-top: 1rem;
      padding-top: 1.5rem;
    }

    .password-gate__toggle {
      font-size: 0.72rem;
      color: #B8A88A;
      letter-spacing: 0.06em;
      cursor: pointer;
      background: none;
      border: none;
      font-family: inherit;
      text-decoration: underline;
      text-underline-offset: 3px;
      padding: 0;
    }

    .password-gate__toggle:hover {
      color: #6B5E4E;
    }

    .password-gate__form {
      display: none;
      flex-direction: column;
      gap: 0.6rem;
      margin-top: 0.9rem;
      max-width: 280px;
      margin-left: auto;
      margin-right: auto;
    }

    .password-gate__form.is-open {
      display: flex;
    }

    .password-gate__input {
      padding: 0.65rem 0.85rem;
      background: rgba(255, 255, 255, 0.65);
      border: 1px solid #D4C5A9;
      border-radius: 2px;
      font-size: 0.85rem;
      color: #2C2C2C;
      font-family: inherit;
      outline: none;
      -webkit-appearance: none;
      transition: border-color 0.2s ease;
    }

    .password-gate__input:focus {
      border-color: #6B5E4E;
    }

    .password-gate__btn {
      padding: 0.65rem 1rem;
      background: transparent;
      color: #6B5E4E;
      border: 1px solid #D4C5A9;
      border-radius: 2px;
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      font-family: inherit;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .password-gate__btn:hover {
      background: #D4C5A9;
      color: #2C2C2C;
    }

    .password-gate__errors {
      color: #8B4444;
      font-size: 0.75rem;
    }

    /* ---- Footer ---- */
    .page-footer {
      text-align: center;
      padding: 1.5rem 1.25rem 2rem;
      font-size: 0.68rem;
      letter-spacing: 0.08em;
      color: #B8A88A;
      text-transform: uppercase;
    }

    /* ---- Responsive ---- */
    @media (min-width: 480px) {
      .capture__form {
        flex-direction: row;
      }

      .capture__input {
        flex: 1;
      }

      .capture__btn {
        width: auto;
        white-space: nowrap;
      }
    }

    @media (min-width: 768px) {
      .hero {
        min-height: 100vh;
        padding: 3rem 2rem 5rem;
      }

      .brand-story {
        padding: 2rem;
      }
    }
  </style>
</head>
<body>

  <main class="hero">
    <div class="hero__bg" role="img" aria-label="Cream and beige lifestyle mood imagery"></div>
    <div class="hero__overlay"></div>

    <div class="hero__content">

      <!-- Brand wordmark -->
      <h1 class="brand-wordmark">Fauna Luxe</h1>
      <p class="brand-tagline">Where the wild meets the luxe.</p>

      <!-- Decorative divider -->
      <div class="divider" aria-hidden="true">
        <span class="divider__line"></span>
        <span class="divider__dot"></span>
        <span class="divider__line"></span>
      </div>

      <!-- Countdown timer -->
      <div class="countdown" aria-label="Countdown to launch">
        <div class="countdown__unit">
          <span class="countdown__value" id="cd-days">--</span>
          <span class="countdown__label">Days</span>
        </div>
        <div class="countdown__unit">
          <span class="countdown__value" id="cd-hours">--</span>
          <span class="countdown__label">Hrs</span>
        </div>
        <div class="countdown__unit">
          <span class="countdown__value" id="cd-mins">--</span>
          <span class="countdown__label">Min</span>
        </div>
        <div class="countdown__unit">
          <span class="countdown__value" id="cd-secs">--</span>
          <span class="countdown__label">Sec</span>
        </div>
      </div>

      <!-- Email capture -->
      <div class="capture">
        <h2 class="capture__headline">Get 15% Off + Shop Before Everyone Else</h2>
        <p class="capture__subtext">Be first to know when we launch.</p>

        {% form 'customer' %}
          {% if form.posted_successfully? %}
            <div class="capture__success">
              <p>You're on the list. We'll be in touch.</p>
            </div>
          {% else %}
            {% if form.errors %}
              <div class="capture__errors">
                {{ form.errors | default_errors }}
              </div>
            {% endif %}
            <div class="capture__form">
              <input
                class="capture__input"
                type="hidden"
                name="contact[tags]"
                value="prospect, coming-soon"
              >
              <input
                class="capture__input"
                type="email"
                name="contact[email]"
                placeholder="Your email address"
                autocomplete="email"
                required
                aria-label="Email address"
              >
              <button class="capture__btn" type="submit">
                Get 15% Off + Shop Before Everyone Else
              </button>
            </div>
          {% endif %}
        {% endform %}
      </div>

      <!-- Brand story snippet -->
      <div class="brand-story">
        <p>
          FAUNA LUXE was born from a single idea: your MacBook deserves to look as considered as the rest of your outfit.
          We design animal print cases in cream and beige tones — not loud, not basic.
          Just wild, quietly.
        </p>
      </div>

      <!-- Password gate — subtle, secondary element -->
      <div class="password-gate">
        <button
          class="password-gate__toggle"
          type="button"
          onclick="document.querySelector('.password-gate__form').classList.toggle('is-open')"
          aria-expanded="false"
          aria-controls="password-gate-form"
        >
          Have a password? Enter store &rarr;
        </button>

        {% form 'storefront_password' %}
          <div class="password-gate__form" id="password-gate-form">
            {% if form.errors %}
              <p class="password-gate__errors">{{ form.errors | default_errors }}</p>
            {% endif %}
            <input
              class="password-gate__input"
              type="password"
              name="password"
              placeholder="Store password"
              autocomplete="current-password"
              aria-label="Store password"
            >
            <button class="password-gate__btn" type="submit">Enter</button>
          </div>
        {% endform %}
      </div>

    </div><!-- /.hero__content -->
  </main>

  <footer class="page-footer">
    <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
  </footer>

  <script>
    // ============================================================
    // FAUNA LUXE — Countdown Timer
    // Vanilla JS — no external dependencies
    //
    // UPDATE THIS DATE when launch date is confirmed:
    // Format: 'YYYY-MM-DDTHH:MM:SS' in local store timezone
    // ============================================================
    const LAUNCH_DATE = new Date('2026-05-26T00:00:00').getTime();

    function tick() {
      var now = Date.now();
      var remaining = Math.max(0, LAUNCH_DATE - now);

      var days  = Math.floor(remaining / (1000 * 60 * 60 * 24));
      var hours = Math.floor((remaining % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      var mins  = Math.floor((remaining % (1000 * 60 * 60)) / (1000 * 60));
      var secs  = Math.floor((remaining % (1000 * 60)) / 1000);

      document.getElementById('cd-days').textContent  = String(days).padStart(2, '0');
      document.getElementById('cd-hours').textContent = String(hours).padStart(2, '0');
      document.getElementById('cd-mins').textContent  = String(mins).padStart(2, '0');
      document.getElementById('cd-secs').textContent  = String(secs).padStart(2, '0');
    }

    setInterval(tick, 1000);
    tick(); // run immediately so there's no blank flash on load

    // Accessibility: update aria-expanded on password toggle
    var toggle = document.querySelector('.password-gate__toggle');
    if (toggle) {
      toggle.addEventListener('click', function() {
        var form = document.getElementById('password-gate-form');
        var isOpen = form && form.classList.contains('is-open');
        toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      });
    }
  </script>

</body>
</html>
